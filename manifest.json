{
  "manifest_version": 3,
  "name": "LILO Tools",
  "description": "Advanced developer toolbox: DNS lookup, image hosting with history, local notes, and secure password generator.",
  "version": "0.9.21",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://dns.google/*",
    "https://1.1.1.1/*",
    "https://cloudflare-dns.com/*",
    "https://freeimage.host/*",
    "http://ip-api.com/*"
  ],
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  }
}